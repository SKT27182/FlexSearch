# =============================================================================
# FlexSearch Backend Environment
# =============================================================================

# -----------------------------------------------------------------------------
# App / Deploy
# -----------------------------------------------------------------------------
API_PORT=8889
SERVICE_PUBLIC_HOST=localhost
CORS_ORIGINS=http://localhost:5144,http://127.0.0.1:5144
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flexsearch
POSTGRES_USER=flexsearch
POSTGRES_PASSWORD=flexsearch_secret
# Optional override for full connection string:
POSTGRES_URL=postgresql+asyncpg://flexsearch:flexsearch_secret@localhost:5432/flexsearch

# Service metadata
POSTGRES_SERVICE_NAME=postgres
POSTGRES_DISPLAY_NAME=PostgreSQL
POSTGRES_CONTAINER_NAME=infra-postgres

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_HNSW_M=16
QDRANT_HNSW_EF=100

# Service metadata
QDRANT_SERVICE_NAME=qdrant
QDRANT_DISPLAY_NAME=Qdrant
QDRANT_CONTAINER_NAME=infra-qdrant

# -----------------------------------------------------------------------------
# MinIO (S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=flexsearch
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Service metadata
MINIO_SERVICE_NAME=minio
MINIO_DISPLAY_NAME=MinIO
MINIO_CONTAINER_NAME=infra-minio

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Embedding / RAG
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EXTRACTION_STRATEGY=ocr
CHUNKING_STRATEGY=fixed_window
RETRIEVAL_STRATEGY=dense
RERANKING_STRATEGY=none

# -----------------------------------------------------------------------------
# LLM (required only for EXTRACTION_STRATEGY=vlm)
# -----------------------------------------------------------------------------
MODEL_NAME=gpt-4o-mini
API_KEY=your-api-key-here
